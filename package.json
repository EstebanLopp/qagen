{
  "name": "@estebanlopp/qagen",
  "version": "0.1.8",
  "description": "Autonomous QA agent that analyzes your web app, generates Playwright tests with AI, and self-heals when selectors break.",
  "main": "index.js",
  "bin": {
    "qagen": "./cli.js"
  },
  "scripts": {
    "test": "npx playwright test --config .qagen/playwright.config.js",
    "generate": "node index.js"
  },
  "keywords": [
    "qa",
    "testing",
    "playwright",
    "ai",
    "automation",
    "self-healing",
    "test-generation"
  ],
  "author": "Esteban Lopez",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EstebanLopp/qagen.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "dotenv": "^17.4.2",
    "openai": "^6.37.0",
    "playwright": "^1.60.0"
  }
}
